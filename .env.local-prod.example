# ============================================================================
# .env.local-prod.example — TEMPLATE for the local development environment.
#
#   cp .env.local-prod.example .env.local-prod
#
# The real file (.env.local-prod) is gitignored. Runs the REAL production code
# paths (NODE_ENV=production) against the local Docker substrate: LocalStack for
# AWS Secrets Manager + KMS + SES, local Postgres / Kafka (KRaft) / Trino / MinIO /
# Neo4j / Redis. This is the ONLY local env — there is no separate "dev".
#
# Selected by the single flag APP_ENV (default local-prod):
#   tsx --env-file=../../.env.${APP_ENV:-local-prod}
# The other env is `.env.production` (real AWS) — see .env.production.example.
#
# Boot (single command):  pnpm dev:up   (compose --wait → migrate → bootstrap →
#                                         one-shot medallion refresh → app)
# The bootstrap step seeds LocalStack SM/KMS from the SEED_* values below.
# ============================================================================

# ── Runtime mode ────────────────────────────────────────────────────────────
# NODE_ENV=production flips the real prod code paths (AwsSecretsProvider, AwsSecretsManager+KMS
# connector secrets, KmsVaultKeyProvider, RedisOAuthStateStore, secure cookies, dev routes OFF).
# Kafka topic prefix is derived from NODE_ENV → 'prod' (collector + core + worker all agree).
NODE_ENV=production
# APP_ENV is the deployment selector. Declared here so EVERY tool that sources this file (e.g.
# `pnpm migrate`, not just `pnpm dev`/`bootstrap` which pass it on the CLI) knows this is local-prod.
APP_ENV=local-prod
COLLECTOR_TOPIC=prod.collector.event.v1
PORT=3001

# ── Local substrate connections (localhost Docker) ──────────────────────────
DATABASE_URL=postgres://brain:brain@localhost:5432/brain
BRAIN_APP_DATABASE_URL=postgres://brain_app:brain_app@localhost:5432/brain
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9092
# Deliberate: keep KafkaJS v2 DefaultPartitioner (murmur2, Java-compatible). Every Brain message
# is tenant-keyed, so partitioning is deterministic regardless — silence the v1→v2 migration nag.
KAFKAJS_NO_PARTITIONER_WARNING=1
APICURIO_URL=http://localhost:8080
S3_ENDPOINT=http://localhost:9000
LITELLM_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
# Serving tier — Trino over Iceberg (StarRocks removed in Brain V4).
TRINO_HOST=localhost
TRINO_PORT=8090
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-local-neo4j-password

# ── AWS → LocalStack (local stand-in for Secrets Manager + KMS + SES) ────────
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
BRAIN_AWS_REGION=us-east-1

# ── App secret REFERENCES (resolved from LocalStack SM, seeded by `pnpm bootstrap`) ──
# These are the SM secret NAMES the app reads — not the secret values. Leave as-is.
# PARITY NOTE (AUD-PROD-014): the bootstrap ALSO mirrors this file's substrate values into the
# 7 prod ESO env-blob shapes (brain/prod/k8s/{core,web,collector,stream-worker,pgbouncer}-env,
# .../iceberg-rest-catalog-db, .../neo4j-auth — flat JSON, contract in
# infra/helm/external-secrets-config/README.md) so prod-on-local rehearses the exact go-live
# secret names. The flat brain/* names below stay the live refs — do NOT repoint them.
JWT_SIGNING_SECRET=brain/jwt-signing-secret
COOKIE_SECRET=brain/cookie-secret
SHOPIFY_CLIENT_SECRET=brain/shopify-client-secret
SHOPIFY_CLIENT_SECRET_ARN=brain/shopify-client-secret
META_APP_SECRET=brain/meta-app-secret
GOOGLE_ADS_CLIENT_SECRET=brain/google-ads-client-secret
# KMS CMK for per-brand connector-secret + PII-vault DEK isolation (D-7/ADR-CM-4).
CONNECTOR_SECRETS_KMS_KEY_ID=alias/brain-connector-secrets
KMS_KEY_ID=alias/brain-connector-secrets

# ── Public OAuth app IDs (non-secret) + callback URLs ───────────────────────
# Register your own dev apps and paste their public client IDs here.
SHOPIFY_CLIENT_ID=replace-with-your-shopify-app-client-id
SHOPIFY_CALLBACK_URL=http://localhost:3001/api/v1/oauth/callback/shopify
META_APP_ID=replace-with-your-meta-app-id
META_CALLBACK_URL=http://localhost:3001/api/v1/connectors/meta/callback
GOOGLE_ADS_CLIENT_ID=replace-with-your-google-ads-client-id
GOOGLE_ADS_DEVELOPER_TOKEN=replace-with-your-google-ads-developer-token
GOOGLE_ADS_CALLBACK_URL=http://localhost:3001/api/v1/connectors/google_ads/callback

# ── Bronze → Iceberg (sole SoR), pixel + connector flags ────────────────────
BRONZE_OPERATIONAL_READ_SOURCE=iceberg
BRONZE_PG_WRITE_ENABLED=false
PIXEL_CONSENT_DEFAULT=granted
# Public HTTPS base the Shopify ScriptTag pixel points at (cloudflared tunnel → collector :8787).
# Run `pnpm dev:pixel-tunnel` and paste the printed URL here (changing it requires reinstalling the pixel).
PIXEL_INGEST_BASE_URL=https://replace-with-your-cloudflared-tunnel.trycloudflare.com
WOOCOMMERCE_LIVE=1
REPULL_DISPATCH_CONCURRENCY=16

# ── Bootstrap-only: RAW secret values `pnpm bootstrap` seeds into LocalStack SM ──
# The app reads the REFERENCES above (NODE_ENV=production → AwsSecretsProvider fetches from SM);
# the bootstrap reads these SEED_* values and writes them into LocalStack SM under the brain/* names.
# These are LOCAL dev placeholders — never real production secrets.
SEED_JWT_SIGNING_SECRET=dev-jwt-signing-secret-not-for-prod-0123456789abcdef
SEED_COOKIE_SECRET=dev-cookie-secret-not-for-prod-0123456789abcdef
SEED_SHOPIFY_CLIENT_SECRET=replace-with-your-shopify-app-secret
SEED_META_APP_SECRET=replace-with-your-meta-app-secret
SEED_GOOGLE_ADS_CLIENT_SECRET=replace-with-your-google-ads-client-secret

# ── Per-brand identity salts (env fallback; the DB salt store is authoritative in prod) ──
# One 64-hex-char salt per brand_id (uppercase, no dashes). The app provisions these at runtime;
# add entries here only to pin a salt for a known local brand. Generate with:
#   openssl rand -hex 32
# IDENTITY_SALT_<BRAND_ID_UPPER_NO_DASHES>=<64-hex-char-salt>

# Bronze landing is the compose kafka-connect service (ADR-0010) — the BRONZE_SOURCE switch is retired.
