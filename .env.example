# ============================================================================
# Layered env loading (per-environment, auto-selected):
#   1. `.env`                         — shared base (copy from this file). Loaded always.
#   2. `.env.${APP_ENV:-dev}`         — per-env OVERRIDE, loaded if present:
#        local/dev → .env.dev          (APP_ENV unset → defaults to `dev`)
#        prod      → .env.prod          (set APP_ENV=prod in the deploy env; NODE_ENV=production)
#      see .env.prod.example for the prod template.
# Wiring (apps/{core,stream-worker,collector}): tsx --env-file=../../.env \
#   --env-file-if-exists=../../.env.${APP_ENV:-dev}. Later file wins on duplicate keys;
#   real shell/container env vars always win over both.
# Env-specific things (connection strings, Bronze cut-over flags) live in the override
# file, NOT here, so prod never inherits a localhost value.
# ============================================================================
# Validated by packages/config (Zod) at boot — a missing/invalid var is a hard failure (doc 05 §8).
# DATABASE_URL = the OWNER/superuser DSN — used for MIGRATIONS (node-pg-migrate, DDL) and dev-only routes.
DATABASE_URL=postgres://brain:brain@localhost:5432/brain
# BRAIN_APP_DATABASE_URL = the RUNTIME app DSN — the non-superuser brain_app role so FORCE RLS actually
# enforces (feat-tenancy-runtime-brain-app A1). core + stream-worker connect with THIS. REQUIRED in prod
# (running as superuser is the R-01 isolation hole); dev defaults to the local brain_app DSN.
BRAIN_APP_DATABASE_URL=postgres://brain_app:brain_app@localhost:5432/brain
REDIS_URL=redis://localhost:6379
REDPANDA_BROKERS=localhost:9092
APICURIO_URL=http://localhost:8080
S3_ENDPOINT=http://localhost:9000
LITELLM_BASE_URL=http://localhost:4000

# ── Pixel (feat-pixel-production-install) ────────────────────────────────────
# Public base URL the pixel asset + auto-injected ScriptTag load from (per-tenant CNAME in prod).
PIXEL_INGEST_BASE_URL=http://localhost:3001
# ITP defense: set 'true' to have the collector stamp brain_anon_id as a server-set first-party
# cookie (durable beyond ITP's 7-day script-cookie cap). Only effective on a first-party CNAME;
# default off keeps the stateless edge (REC-4).
PIXEL_FIRST_PARTY_COOKIE=false
# Pixel consent fallback: 'granted' makes consent() default to granted ONLY when the storefront
# exposes no consent signal (no CMP). Unset/strict = fail-safe-absent (R3 drops). Merchant-accepted.
PIXEL_CONSENT_DEFAULT=
# StarRocks (Silver serving). Enables the stream-worker DQ Bronze↔Silver reconciliation check and
# core's Silver reads. WITHOUT STARROCKS_HOST the DQ reconciliation emits an honest 'silver_disabled'
# grade D (never a false pass). brain_analytics is the SELECT-only user created by db/starrocks/bootstrap.sql.
STARROCKS_HOST=localhost
STARROCKS_PORT=9030
STARROCKS_ANALYTICS_USER=brain_analytics
STARROCKS_ANALYTICS_PASSWORD=brain_analytics_dev
# Bronze source for OPERATIONAL reads (ADR-0002 Slice 5): 'pg' (bronze_events, default) or 'iceberg'
# (collector_events via the StarRocks external catalog + the brand-isolated withSilverBrand seam).
# Reversible; flip to 'iceberg' per-env once parity is proven, ahead of retiring the PG Bronze write.
BRONZE_OPERATIONAL_READ_SOURCE=pg
# PG Bronze write switch (ADR-0002 Slice 6). Default ENABLED. Set =false ONLY to RETIRE the PG
# bronze_events write so Spark→Iceberg is the sole Bronze SoR. Prereqs before flipping: all readers
# on Iceberg (Slice 5 — in progress), and a green parity soak. (The Spark writer now enforces R2/R3 —
# bronze_materialize.py gate_and_map — so Iceberg holds the same admission set as PG Bronze.)
BRONZE_PG_WRITE_ENABLED=true
# Never commit real secrets. Staging/prod inject via External-Secrets → AWS Secrets Manager.
