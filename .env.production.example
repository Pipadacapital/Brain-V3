# ============================================================================
# .env.production.example — template for the REAL PRODUCTION environment.
#
# There are exactly TWO environments, selected by the single flag APP_ENV:
#   APP_ENV=local-prod (default) → .env.local-prod  (local Docker + LocalStack)
#   APP_ENV=production           → .env.production   (real AWS — this file's shape)
# Each env file is SELF-CONTAINED (a single --env-file; there is no shared base):
#   tsx --env-file=../../.env.${APP_ENV:-local-prod}
#
# For real prod: copy to `.env.production` (gitignored) and fill real values, OR — preferred —
# inject these via External-Secrets ← AWS Secrets Manager into the container env, and set
# APP_ENV=production in the deploy environment (e.g. the K8s pod env).
#
# NODE_ENV=production flips the prod code paths AND drives the Kafka topic prefix → 'prod'
# (core + stream-worker + collector all derive 'prod' from NODE_ENV, so they agree on
# `prod.collector.event.v1`). APP_ENV is ONLY the env-file selector — it does not affect topics.
# ============================================================================

# ── Environment discriminator ───────────────────────────────────────────────
NODE_ENV=production
# APP_ENV is the deployment selector (real-prod vs local-prod). Declare it IN the env file so EVERY tool
# that sources this file — not just `pnpm dev`/`bootstrap` which pass it on the CLI — resolves the right
# environment. In particular `pnpm migrate` derives the SQL `app.env` GUC from APP_ENV→NODE_ENV: without
# this line a prod-local run (NODE_ENV=production, no APP_ENV) would resolve app.env='production' and trip
# the dev-only guards (e.g. 0024 dev_secret) that must fire ONLY for REAL production.
APP_ENV=production
COLLECTOR_TOPIC=prod.collector.event.v1
# Listen port (schema default 3000 for core / 3001 for collector). Set explicitly if your ingress
# expects a fixed port; local-prod pins core to 3001.
# PORT=3000
# Repull fan-out concurrency (schema default 16). Tune to the prod worker's CPU/rate-limit budget.
# REPULL_DISPATCH_CONCURRENCY=16

# ── Connections (prod — injected via External-Secrets in the real deploy) ────
DATABASE_URL=postgres://USER:PASSWORD@PROD_PG_HOST:5432/brain
BRAIN_APP_DATABASE_URL=postgres://brain_app:PASSWORD@PROD_PG_HOST:5432/brain
REDIS_URL=redis://PROD_REDIS_HOST:6379
KAFKA_BROKERS=PROD_BROKER_1:9092,PROD_BROKER_2:9092
KAFKA_BROKERS=PROD_BROKER_1:9092,PROD_BROKER_2:9092
# Deliberate: keep KafkaJS v2 DefaultPartitioner (murmur2, Java-compatible). Every Brain message
# is tenant-keyed, so partitioning is deterministic regardless — silence the v1→v2 migration nag.
KAFKAJS_NO_PARTITIONER_WARNING=1
# Redpanda SASL (prod brokers are authenticated; local Docker has none, so these are unset there).
# The centralized @brain/config schema defaults these to empty → MUST be set in prod or the broker
# rejects the connection. Inject the password via External-Secrets, not a literal.
KAFKA_SASL_USERNAME=brain-prod
KAFKA_SASL_PASSWORD=CHANGE_ME
# Schema registry (Apicurio). Defaults to http://localhost:8080 in the schema — set the prod URL or
# producers/consumers register/fetch Avro schemas against a non-existent local registry.
APICURIO_URL=http://PROD_APICURIO_HOST:8080

# Trino serving (Trino-over-Iceberg replaced StarRocks). The app/BFF/metric-engine read the
# brain_serving.mv_* views over Trino, fronted by the Redis analytics cache. No StarRocks.
TRINO_HOST=PROD_TRINO_COORDINATOR_HOST
TRINO_PORT=8080
TRINO_SERVING_CACHE_TTL_MS=300000
SERVING_VERSION=v1

# ── Identity graph (Neo4j — the identity SoR per ADR-0004) ────────────────────
# CRITICAL: the @brain/config schema defaults these to bolt://localhost:7687 / neo4j / neo4j. With
# them unset in prod, core + stream-worker would SILENTLY connect to a local box with default creds
# (identity resolution + export break, or worse, hit the wrong store). Always set them in prod.
NEO4J_URI=bolt://PROD_NEO4J_HOST:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME

# ── Observability (OTel export — vendor-neutral OTLP) ────────────────────────
# Unset → @brain/observability stays on no-op providers and EXPORTS NOTHING. Set the prod collector
# endpoint so traces/metrics/logs (correlation_id + brand_id on every signal) actually ship.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability:4317

# ── Region ───────────────────────────────────────────────────────────────────
# Schema default 'IN'. Set per deployment region (drives region-varying behaviour / residency seam).
BRAIN_REGION_CODE=IN

# ── AWS (real prod — IRSA creds; NO AWS_ENDPOINT_URL) ────────────────────────
AWS_REGION=ap-south-1
# SES is region-scoped — the From identity (EMAIL_FROM_ADDRESS) must be a VERIFIED identity in
# whichever region SES sends from. Defaults to AWS_REGION; set SES_REGION only if your verified
# SES setup lives in a different region than the rest of the stack. (createEmailAdapter resolves
# SES_REGION → AWS_REGION → ap-south-1; do NOT rely on the old hardcoded default.)
# SES_REGION=ap-south-1

# ── Secret REFERENCES (the env holds the ARN/name; AwsSecretsProvider fetches) ─
JWT_SIGNING_SECRET=arn:aws:secretsmanager:REGION:ACCT:secret:brain/jwt-signing-secret
COOKIE_SECRET=arn:aws:secretsmanager:REGION:ACCT:secret:brain/cookie-secret
# Public Shopify app id (NOT a secret) — the OAuth authorize URL can't be built without it. The
# template carried SHOPIFY_CLIENT_SECRET but not the *_ID; both are required for Shopify connect.
SHOPIFY_CLIENT_ID=<shopify-app-client-id>
SHOPIFY_CLIENT_SECRET=arn:aws:secretsmanager:REGION:ACCT:secret:brain/shopify-client-secret
# Customer-managed KMS CMK for per-brand connector-secret + PII-vault DEK isolation (D-7/ADR-CM-4).
CONNECTOR_SECRETS_KMS_KEY_ID=arn:aws:kms:REGION:ACCT:key/CMK-ID
# Per-brand identity-crypto DEK CMK. Schema falls back to CONNECTOR_SECRETS_KMS_KEY_ID; set
# explicitly if identity crypto uses a separate CMK from connector-secret isolation.
IDENTITY_CRYPTO_KMS_KEY_ID=arn:aws:kms:REGION:ACCT:key/CMK-ID

# ── Ad-platform OAuth app creds (REQUIRED — core FAIL-CLOSES at boot without the *_SECRET refs) ─
# HandleMeta/GoogleAdsOAuthCallbackCommand + the meta-token-refresh job need these. The *_ID values
# are public (raw); the *_SECRET values are Secrets Manager ARNs resolved at startup. Omitting either
# *_SECRET aborts core boot in production (apps/core/src/main.ts).
META_APP_ID=<meta-app-id>
META_APP_SECRET=arn:aws:secretsmanager:REGION:ACCT:secret:brain/meta-app-secret
GOOGLE_ADS_CLIENT_ID=<google-ads-oauth-client-id>
GOOGLE_ADS_CLIENT_SECRET=arn:aws:secretsmanager:REGION:ACCT:secret:brain/google-ads-client-secret

# ── Pixel consent default (SEC-1 — fail-safe-absent) ─────────────────────────
# DELIBERATELY UNSET in prod. With no value the collector/stream-worker treat consent as
# ABSENT (fail-closed: events without an explicit consent envelope are quarantined, not
# landed in Bronze). Defaulting this to `granted` is a per-merchant / per-region COMPLIANCE
# decision (GDPR/DPDP opt-in jurisdictions cannot blanket-grant) — it must NEVER be baked
# into the prod template. .env.local-prod sets `granted` for local convenience; prod leaves it empty.
# PIXEL_CONSENT_DEFAULT=

# ── Per-brand identity salts ─────────────────────────────────────────────────
# Prod has NO deterministic dev-salt fallback (resolveSaltHex gates it on NODE_ENV!='production').
# Each brand needs IDENTITY_SALT_<BRAND_UUID_NODASHES_UPPER>=<64-hex> (resolved via secrets in real
# prod), else the D-2 guard hard-crashes PII hashing in the identity bridge + ingest repull mapper.
# Locally, `pnpm bootstrap` seeds these into .env.local-prod (= each brand's dev salt, for
# hash continuity). Example shape:
# IDENTITY_SALT_124E6AF5E6C54B85BF437B36FA528101=<64-hex-salt>

# ── Public base URLs (prod origins — local uses http://localhost:*) ──────────
# Web build-time public API origin (the browser calls this). MUST be the prod API origin.
NEXT_PUBLIC_API_BASE_URL=https://api.brain.example.com
# Server-side inter-service + outbound URLs. Schema defaults are localhost — set prod hostnames so
# the BFF, core API and the webhook callback URLs vendors call back on are correct.
CORE_API_URL=https://api.brain.example.com
BFF_BASE_URL=https://api.brain.example.com
BRAIN_WEBHOOK_BASE_URL=https://api.brain.example.com

# ── Connectors (gating + endpoints; *_KEY values via External-Secrets) ───────
# Live-mode gates (schema defaults treat unset as not-live). Set per the connectors you run in prod.
WOOCOMMERCE_LIVE=1
SHIPROCKET_LIVE=1
SHIPROCKET_BASE_URL=https://apiv2.shiprocket.in
SHIPROCKET_SHIPMENTS_KEY=arn:aws:secretsmanager:REGION:ACCT:secret:brain/shiprocket-shipments-key

# ── Pixel ingest host (public HTTPS the storefront pixel posts to → collector) ─
# Schema default is '' . In prod this is your real first-party/pixel domain (NOT a cloudflared tunnel).
PIXEL_INGEST_BASE_URL=https://pixel.brain.example.com

# ── Bronze → Iceberg cut-over flags (ADR-0002 / RB-5) ───────────────────────
# SHIP SAFE on a fresh env: read=pg, write=true, with the Spark→Iceberg dual-sink running
# (sparkBronze.enabled=true). GO LIVE per docs/runbooks/RB-5 — only after the parity soak is
# green flip the read, then after it bakes flip the write:
#   BRONZE_OPERATIONAL_READ_SOURCE=iceberg   # Phase 3 — reads from Iceberg (drives core + dbt)
#   BRONZE_PG_WRITE_ENABLED=false            # Phase 4 — retire the PG bronze write
# Each is reversible. Do NOT jump straight to iceberg/false on a fresh environment.
BRONZE_OPERATIONAL_READ_SOURCE=pg
BRONZE_PG_WRITE_ENABLED=true
