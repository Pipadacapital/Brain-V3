{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "NODE_ENV", "APP_ENV", "PORT", "DATABASE_URL", "BRAIN_APP_DATABASE_URL", "REDIS_URL",
    "KAFKA_BROKERS", "KAFKA_SASL_USERNAME", "KAFKA_SASL_PASSWORD", "COLLECTOR_TOPIC",
    "APICURIO_URL", "S3_ENDPOINT", "LITELLM_BASE_URL",
    "AWS_REGION", "AWS_ENDPOINT_URL", "AWS_ACCESS_KEY_ID", "AWS_SECRET_ACCESS_KEY",
    "JWT_SIGNING_SECRET", "COOKIE_SECRET", "SHOPIFY_CLIENT_ID", "SHOPIFY_CLIENT_SECRET",
    "CONNECTOR_SECRETS_KMS_KEY_ID", "PIXEL_INGEST_BASE_URL", "PIXEL_CONSENT_DEFAULT",
    "STARROCKS_HOST", "STARROCKS_PORT", "STARROCKS_ANALYTICS_USER", "STARROCKS_ANALYTICS_PASSWORD",
    "BRONZE_OPERATIONAL_READ_SOURCE", "BRONZE_PG_WRITE_ENABLED",
    "NEXT_PUBLIC_API_BASE_URL"
  ],
  "tasks": {
    "build":          { "dependsOn": ["^build"], "outputs": ["dist/**"] },
    "typecheck":      { "dependsOn": ["^build"] },
    "lint":           {},
    "test:unit":      { "dependsOn": ["^build"] },
    "test:contract":  { "dependsOn": ["^build", "gen:contracts"] },
    "test:isolation": { "dependsOn": ["^build"] },
    "test:parity":    { "dependsOn": ["^build"] },
    "gen:contracts":  {
      "outputs": [
        "packages/contracts/generated/**",
        "packages/contracts/generated/types/**",
        "packages/contracts/generated/openapi/**",
        "packages/contracts/generated/avro/**",
        "packages/contracts/generated/mcp/**"
      ]
    },
    "dev":            { "cache": false, "persistent": true }
  }
}
