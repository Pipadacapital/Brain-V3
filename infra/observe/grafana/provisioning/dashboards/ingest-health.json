{
  "uid": "brain-ingest-health",
  "title": "Brain — Ingest Health",
  "description": "Collector accept rate, spool-full shedding, Bronze write rate, DLQ growth, consumer lag.",
  "tags": ["brain", "ingest"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Collector Accept Rate (events/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(brain_collector_accept_total[1m]))",
          "legendFormat": "accept/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Spool-Full Shedding Rate (events/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(brain_collector_spool_full_total[1m]))",
          "legendFormat": "shed/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "fixedColor": "red", "mode": "fixed" } }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Bronze Write Rate (rows/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(brain_bronze_write_total[1m]))",
          "legendFormat": "writes/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Consumer Group Lag",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (redpanda_group) (redpanda_kafka_consumer_group_lag_sum{redpanda_group=~\"stream-worker-.*|.*-bridge\"})",
          "legendFormat": "{{ redpanda_group }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "DLQ Topic Offset Growth",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (redpanda_topic) (rate(redpanda_kafka_max_offset{redpanda_topic=~\".*\\.dlq\"}[5m]))",
          "legendFormat": "{{ redpanda_topic }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "orange", "mode": "fixed" } }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Dedup Conflicts (events/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (event_name) (rate(brain_collector_dedup_conflict_total[1m]))",
          "legendFormat": "{{ event_name }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Circuit Breaker Rejections (15m)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (name) (increase(brain_circuit_breaker_rejected_total[15m]))",
          "legendFormat": "{{ name }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 10 }
          ]}
        }
      }
    }
  ]
}
