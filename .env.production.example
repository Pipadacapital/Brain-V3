# ============================================================================
# .env.production.example — template for the PRODUCTION environment override.
#
# Copy to `.env.production` (gitignored) and fill real values, OR — the real
# prod path — inject these via External-Secrets ← AWS Secrets Manager into the
# container env. Auto-loaded after the shared base `.env` when APP_ENV=production:
#   tsx --env-file=../../.env --env-file-if-exists=../../.env.${APP_ENV:-dev}
#
# Set APP_ENV=production in the deploy environment (e.g. the K8s pod env) so this
# file / these secrets are selected and the Kafka topic prefix becomes
# `production.collector.event.v1` (vs `dev.*` locally). Every key here OVERRIDES
# the same key in `.env`, so prod NEVER inherits a localhost connection string.
# ============================================================================

# ── Environment discriminator ───────────────────────────────────────────────
APP_ENV=production
NODE_ENV=production

# ── Connections (prod — injected via External-Secrets in the real deploy) ────
DATABASE_URL=postgres://USER:PASSWORD@PROD_PG_HOST:5432/brain
BRAIN_APP_DATABASE_URL=postgres://brain_app:PASSWORD@PROD_PG_HOST:5432/brain
REDIS_URL=redis://PROD_REDIS_HOST:6379
REDPANDA_BROKERS=PROD_BROKER_1:9092,PROD_BROKER_2:9092
# StarRocks (analytics read path; also the Iceberg external-catalog reader)
STARROCKS_HOST=PROD_STARROCKS_FE_HOST
STARROCKS_PORT=9030
STARROCKS_ANALYTICS_USER=brain_analytics
STARROCKS_ANALYTICS_PASSWORD=CHANGE_ME

# ── Bronze → Iceberg cut-over flags (ADR-0002 / RB-5) ───────────────────────
# SHIP SAFE: a fresh prod deploy starts on Postgres bronze (read=pg, write=true),
# with the Spark→Iceberg dual-sink running in parallel (sparkBronze.enabled=true in
# the cronworkflows chart). Then GO LIVE by following docs/runbooks/RB-5: only after
# the parity soak is green, flip the read; after it bakes, flip the write:
#   BRONZE_OPERATIONAL_READ_SOURCE=iceberg   # Phase 3 — reads from Iceberg
#   BRONZE_PG_WRITE_ENABLED=false            # Phase 4 — retire the PG bronze write
# Each is reversible (flip back). Do NOT jump straight to iceberg/false on a fresh
# environment — the green parity soak is the entire safety basis for the cut-over.
BRONZE_OPERATIONAL_READ_SOURCE=pg
BRONZE_PG_WRITE_ENABLED=true
