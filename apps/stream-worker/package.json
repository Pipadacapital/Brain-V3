{
  "name": "@brain/stream-worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "dev": "tsx watch --env-file=../../.env.${APP_ENV:-local-prod} src/main.ts",
    "dlq:redrive": "tsx --env-file=../../.env.${APP_ENV:-local-prod} src/jobs/dlq-redrive/run.ts",
    "test:unit": "vitest run --passWithNoTests --exclude '**/*.e2e.test.ts' --exclude '**/*.live.test.ts' --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run --passWithNoTests integration.test",
    "test:e2e": "vitest run --no-file-parallelism src/tests/bronze.e2e.test.ts src/tests/ingest-scheduler.e2e.test.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@brain/ad-spend-mapper": "workspace:*",
    "@brain/ga4-mapper": "workspace:*",
    "@brain/attribution-writer": "workspace:*",
    "@brain/audit": "workspace:*",
    "@brain/config": "workspace:*",
    "@brain/connector-core": "workspace:*",
    "@brain/connector-secrets": "workspace:*",
    "@brain/contracts": "workspace:*",
    "@brain/db": "workspace:*",
    "@brain/events": "workspace:*",
    "@brain/gokwik-mapper": "workspace:*",
    "@brain/identity-core": "workspace:*",
    "@brain/metric-engine": "workspace:*",
    "@brain/observability": "workspace:*",
    "@brain/pii-vault": "workspace:*",
    "@brain/platform-flags": "workspace:*",
    "@brain/razorpay-mapper": "workspace:*",
    "@brain/shiprocket-mapper": "workspace:*",
    "@brain/shopflo-mapper": "workspace:*",
    "@brain/shopify-mapper": "workspace:*",
    "@brain/tenant-context": "workspace:*",
    "@brain/woocommerce-mapper": "workspace:*",
    "ioredis": "^5.11.1",
    "kafkajs": "^2.2.4",
    "mysql2": "^3.22.5",
    "neo4j-driver": "^5.21.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.6",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
