{
  // Dead-code report for the Brain monorepo (pnpm workspaces). NON-BLOCKING — surfaced by
  // .github/workflows/knip.yml so unused files / exports / deps are caught going forward
  // without gating merges. Knip auto-discovers the apps/* packages/* tools/* workspaces from
  // pnpm-workspace.yaml; per-workspace overrides below name each runtime entrypoint so legit
  // roots are not flagged as dead.
  // (jsonc, not json: knip@5 rejects the old "//" comment-key workaround as an unrecognized key.)
  "$schema": "https://unpkg.com/knip@5/schema.json",
  // Types/interfaces exported next to the functions whose signatures use them are the
  // function's NAMED signature (and required for declaration emit in packages/*) —
  // stripping `export` there is churn, not cleanup. Functions/consts stay strictly reported.
  "ignoreExportsUsedInFile": { "interface": true, "type": true },
  // cloudflared is an OS-level binary (brew/apt), invoked by package.json dev:tunnel and
  // tools/dev/*-tunnel.sh — not an npm dependency.
  "ignoreBinaries": ["docker", "docker compose", "trino", "spark-submit", "cloudflared"],
  "ignoreDependencies": [
    "@brain/.*",
    // NEVER remove: loaded via a dynamic import in packages/pii-vault/src/index.ts — removing
    // it from apps/core reintroduces the empty-keyring-DEK cold-start bug.
    "@aws-sdk/client-kms",
    // NEVER remove: hidden dynamic import in apps/core notification/internal/ses-adapter.ts.
    "@aws-sdk/client-ses",
    // Load-bearing root devDep: tools/dev/v4-refresh-loop.sh runs `pnpm exec tsx`.
    "tsx",
    // Configured via .prettierrc.
    "prettier"
  ],
  "ignore": [
    "**/dist/**",
    "**/.next/**",
    "**/.turbo/**",
    "**/coverage/**",
    "db/**",
    "tools/seed/**",
    // k6 CLI scripts, invoked per docs/runbooks/prod-deploy.md — not part of the import graph.
    "tools/load-test/**",
    // Negative-control fixtures for the custom eslint rules — intentionally "dead".
    "tools/eslint-rules/fixtures/**",
    // Shopify-CLI-built web pixel extension (shopify.extension.toml owns its entrypoint).
    "extensions/**",
    // Workflow-tool script launched dynamically by path (cleanup-plan §3.11: orchestrator
    // invocation is out-of-graph) — not imported anywhere by design.
    "tools/dev/e2e-gate.wf.js",
    // Manual ops fixture, a documented runbook step (docs/runbooks/RB-4-local-lakehouse.md).
    "tools/pixel-fixture/seed-touchpoints.mjs",
    // AUD-IMPL-022 decision: KEEP generating. Part of the D.2 semantic-metrics codegen set
    // (views/preaggs/catalog.json/metric-ids.ts), snapshot-tested against a fresh compile —
    // the compile-time metric-id enum awaiting consumers, not an orphan to delete piecemeal.
    "packages/semantic-metrics/src/generated/metric-ids.ts",
    // Workflow-tool scripts launched by path (PR_BODY.md documents the reproducible
    // blueprint workflow; v4-naming-guard carves the dir out for the same reason).
    ".eos-workflows/**",
    // Claude Code harness/workflow scripts (skills, saved workflows) are launched by
    // path by the agent runtime, never imported by app code — out-of-graph like
    // .eos-workflows above. Required so the now-BLOCKING knip gate (knip.yml) stays
    // green on baseline instead of tripping on e.g. wave1-parallel-prep.js.
    ".claude/**",
    // Boundary-seam barrel: eslint.config.mjs bans cross-module reach-around past index.ts,
    // so this file is the connector module's only legal cross-module import point. The
    // composition root (main.ts/bootstrap) is the sanctioned deep-import exception, hence
    // knip sees no importers today (AUD-CODE-011).
    "apps/core/src/modules/connector/index.ts"
  ],
  "workspaces": {
    "apps/core": { "entry": ["src/main.ts", "src/index.ts"] },
    "apps/collector": { "entry": ["src/main.ts", "src/index.ts"] },
    "apps/stream-worker": {
      "entry": [
        "src/main.ts",
        "src/index.ts",
        // CLI/cron job entrypoints: invoked by tools/dev/v4-refresh-loop.sh and the Argo
        // cronworkflows (infra/helm/cronworkflows/values.yaml), not imported from main.ts.
        "src/jobs/**/run.ts",
        "src/jobs/*.ts",
        // Operator CLI.
        "src/jobs/identity/replay-identity.ts"
      ]
    },
    "apps/web": {
      // The app lives at apps/web/app + components (no src/ prefix).
      "entry": [
        "app/**/{page,layout,loading,error,not-found,route,template,default}.tsx",
        "middleware.ts",
        "next.config.{js,mjs,ts}",
        "playwright.config.ts",
        "playwright.demo.config.ts"
      ],
      "ignore": ["components/ui/**", "e2e/**"]
    },
    "packages/*": { "entry": ["src/index.ts"] },
    "packages/pixel-sdk": {
      // src/asset/entry.ts is the esbuild entrypoint of the served /pixel.js IIFE bundle
      // (tools/pixel-asset-bundle.mjs entryPoints) — out-of-path for knip's import graph, so
      // without this it false-positives entry.ts + auto-instrument.ts as unused (AUD-IMPL-022).
      "entry": ["src/index.ts", "src/asset/entry.ts"]
    },
    "tools/*": { "entry": ["src/index.ts", "src/main.ts", "*.config.ts"] },
    // Operator-run DPDP drill harness (AUD-OPS-040): launched via `pnpm --filter
    // @brain/tool-privacy drill`, never imported — the script IS the entrypoint.
    "tools/privacy": { "entry": ["src/rtbf-drill.ts"] }
  }
}
