# Terraform — provider plugins and local cache (never commit binaries; run `terraform init`)
**/.terraform/
!**/.terraform.lock.hcl

# Engineering OS — derived/runtime files (everything else under .engineering-os/ stays committed)
.engineering-os/index/
.engineering-os/live.log
.engineering-os/dashboard.html
.engineering-os/spawn-heartbeat.jsonl
.engineering-os/state/*.bak*

# dbt — derived/build artifacts + local dev venv (never commit; run `make silver-run`)
.dbt-venv/
db/dbt/target/
db/dbt/dbt_packages/
db/dbt/logs/

# Playwright e2e artifacts
apps/web/test-results/
apps/web/playwright-report/
apps/web/playwright/.cache/
test-results/

# Python bytecode (Spark/Iceberg helper scripts)
__pycache__/
