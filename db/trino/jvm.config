-server
-agentpath:/usr/lib/trino/bin/libjvmkill.so
# BOUNDED HEAP (Brain V4 local-prod): the stock image uses MaxRAMPercentage=80 of the
# container's *visible* memory. With no compose mem_limit, Trino sees the whole Docker VM
# (~23GB) and sizes its heap to ~18GB → it balloons under refresh-time query load and the
# Docker VM OOM-killer takes it down (exit 137), killing the SOLE serving engine and 500-ing
# every BFF read. We pin the container to mem_limit=7g (docker-compose.yml) and cap the heap
# at 70% of that (~4.9GB) with a low initial floor, leaving ~1GB+ headroom for non-heap
# (code cache / metaspace / direct buffers). Our data is tiny (queries finish <600ms), so a
# ~5GB heap is ample. Predictable footprint + restart:unless-stopped = the serving tier can
# no longer be silently knocked out by a refresh.
-XX:InitialRAMPercentage=35
-XX:MaxRAMPercentage=70
-XX:G1HeapRegionSize=32M
-XX:+ExplicitGCInvokesConcurrent
-XX:+HeapDumpOnOutOfMemoryError
-XX:+ExitOnOutOfMemoryError
-XX:-OmitStackTraceInFastThrow
-XX:ReservedCodeCacheSize=256M
-XX:PerMethodRecompilationCutoff=10000
-XX:PerBytecodeRecompilationCutoff=10000
-Djdk.attach.allowAttachSelf=true
-Djdk.nio.maxCachedBufferSize=2000000
# Allow loading dynamic agent used by JOL
-XX:+EnableDynamicAgentLoading
