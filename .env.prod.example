# ============================================================================
# .env.prod.example — template for the PRODUCTION environment override.
#
# Copy to `.env.prod` (gitignored) and fill real values, OR — the real prod path —
# inject these via External-Secrets ← AWS Secrets Manager into the container env.
# Auto-loaded after the shared base `.env` when APP_ENV=prod:
#   tsx --env-file=../../.env --env-file-if-exists=../../.env.${APP_ENV:-dev}
#
# Set APP_ENV=prod in the deploy environment (e.g. the K8s pod env). NOTE the naming:
# NODE_ENV=production (the @brain/config enum) flips the prod code paths; APP_ENV=prod
# (short) is the Kafka topic prefix — both must be set, and APP_ENV MUST be `prod` so the
# core live lane + stream-worker + collector all agree on `prod.collector.event.v1`
# (the collector derives 'prod' from NODE_ENV). Every key here OVERRIDES `.env`, so prod
# never inherits a localhost value.
#
# For a LOCAL production-faithful run, use `.env.prod` (gitignored) which points the AWS
# clients at LocalStack via AWS_ENDPOINT_URL — see RB-5 "prod-on-local".
# ============================================================================

# ── Environment discriminator ───────────────────────────────────────────────
NODE_ENV=production
APP_ENV=prod
COLLECTOR_TOPIC=prod.collector.event.v1

# ── Connections (prod — injected via External-Secrets in the real deploy) ────
DATABASE_URL=postgres://USER:PASSWORD@PROD_PG_HOST:5432/brain
BRAIN_APP_DATABASE_URL=postgres://brain_app:PASSWORD@PROD_PG_HOST:5432/brain
REDIS_URL=redis://PROD_REDIS_HOST:6379
REDPANDA_BROKERS=PROD_BROKER_1:9092,PROD_BROKER_2:9092
KAFKA_BROKERS=PROD_BROKER_1:9092,PROD_BROKER_2:9092
# StarRocks (analytics read path; also the Iceberg external-catalog reader)
STARROCKS_HOST=PROD_STARROCKS_FE_HOST
STARROCKS_PORT=9030
STARROCKS_ANALYTICS_USER=brain_analytics
STARROCKS_ANALYTICS_PASSWORD=CHANGE_ME

# ── AWS (real prod — IRSA creds; NO AWS_ENDPOINT_URL) ────────────────────────
AWS_REGION=ap-south-1

# ── Secret REFERENCES (the env holds the ARN/name; AwsSecretsProvider fetches) ─
JWT_SIGNING_SECRET=arn:aws:secretsmanager:REGION:ACCT:secret:brain/jwt-signing-secret
COOKIE_SECRET=arn:aws:secretsmanager:REGION:ACCT:secret:brain/cookie-secret
SHOPIFY_CLIENT_SECRET=arn:aws:secretsmanager:REGION:ACCT:secret:brain/shopify-client-secret
# Customer-managed KMS CMK for per-brand connector-secret + PII-vault DEK isolation (D-7/ADR-CM-4).
CONNECTOR_SECRETS_KMS_KEY_ID=arn:aws:kms:REGION:ACCT:key/CMK-ID

# ── Bronze → Iceberg cut-over flags (ADR-0002 / RB-5) ───────────────────────
# SHIP SAFE on a fresh env: read=pg, write=true, with the Spark→Iceberg dual-sink running
# (sparkBronze.enabled=true). GO LIVE per docs/runbooks/RB-5 — only after the parity soak is
# green flip the read, then after it bakes flip the write:
#   BRONZE_OPERATIONAL_READ_SOURCE=iceberg   # Phase 3 — reads from Iceberg (drives core + dbt)
#   BRONZE_PG_WRITE_ENABLED=false            # Phase 4 — retire the PG bronze write
# Each is reversible. Do NOT jump straight to iceberg/false on a fresh environment.
BRONZE_OPERATIONAL_READ_SOURCE=pg
BRONZE_PG_WRITE_ENABLED=true
