{
  "name": "@brain/collector",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "dev": "PORT=8787 tsx watch --env-file=../../.env.${APP_ENV:-local-prod} src/main.ts",
    "start": "node dist/main.js",
    "test:unit": "vitest run --passWithNoTests --exclude '**/*.e2e.test.ts' --exclude '**/*.live.test.ts' --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run --passWithNoTests integration.test"
  },
  "dependencies": {
    "fastify": "^4.28.0",
    "pg": "^8.13.0",
    "kafkajs": "^2.2.4",
    "ioredis": "^5.11.1",
    "@brain/contracts": "workspace:*",
    "@brain/events": "workspace:*",
    "@brain/pixel-sdk": "workspace:*",
    "@brain/platform-flags": "workspace:*",
    "@brain/observability": "workspace:*",
    "@brain/tenant-context": "workspace:*",
    "@brain/config": "workspace:*"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "@types/node": "^22.0.0",
    "vitest": "^2.1.0",
    "tsx": "^4.22.4"
  }
}
