{
  "name": "@brain/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "dev": "tsx watch --env-file=../../.env src/main.ts",
    "test:unit": "vitest run --passWithNoTests",
    "test:isolation": "vitest run isolation --passWithNoTests",
    "test:parity": "vitest run parity --passWithNoTests"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/client-secrets-manager": "^3.600.0",
    "@brain/ai-gateway-client": "workspace:*",
    "@brain/attribution-writer": "workspace:*",
    "@brain/audit": "workspace:*",
    "@brain/config": "workspace:*",
    "@brain/contracts": "workspace:*",
    "@brain/db": "workspace:*",
    "@brain/events": "workspace:*",
    "@brain/feature-flags": "workspace:*",
    "@brain/identity-core": "workspace:*",
    "@brain/metric-engine": "workspace:*",
    "@brain/money": "workspace:*",
    "@brain/observability": "workspace:*",
    "@brain/pii-vault": "workspace:*",
    "@brain/pixel-sdk": "workspace:*",
    "@brain/razorpay-mapper": "workspace:*",
    "@brain/shopflo-mapper": "workspace:*",
    "@brain/shopify-mapper": "workspace:*",
    "@brain/tenant-context": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "argon2": "^0.44.0",
    "fastify": "^5.7.2",
    "fastify-raw-body": "^5.0.0",
    "ioredis": "^5.11.1",
    "kafkajs": "^2.2.4",
    "mysql2": "^3.22.5",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/argon2": "^0.15.3",
    "@types/pg": "^8.11.6",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
