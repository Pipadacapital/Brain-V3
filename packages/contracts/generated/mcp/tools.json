                  "type": "string",
                  "format": "uuid"
                },
                "rule_version": {
                  "type": "string"
                },
                "confidence": {
                  "type": "integer"
                },
                "reasons": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "identifier_combo": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "identifier_type": {
                        "type": "string"
                      },
                      "identifier_hash_prefix": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "identifier_type",
